{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create Review ZIP",
      "type": "shell",
      "command": "powershell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/create-review-zip.ps1"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Apply ChatGPT Delivery",
      "type": "shell",
      "command": "powershell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/apply-delivery.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Engineering: Doctor",
      "type": "shell",
      "command": "python -m tools.engineering doctor",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Engineering: Context",
      "type": "shell",
      "command": "python -m tools.engineering context",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Engineering: Prompt (Gemini)",
      "type": "shell",
      "command": "python -m tools.engineering prompt gemini",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Engineering: Prepare Gemini",
      "type": "shell",
      "command": "python -m tools.engineering prepare gemini",
      "presentation": { "reveal": "always" },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ]
}