{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create Review ZIP",
      "type": "shell",
      "command": "powershell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/create-review-zip.ps1"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Apply ChatGPT Delivery",
      "type": "shell",
      "command": "powershell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/apply-delivery.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}